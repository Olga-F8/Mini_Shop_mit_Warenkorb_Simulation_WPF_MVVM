<UserControl x:Class="Mini_Shop_mit_Warenkorb_Simulation_WPF.Views.CheckoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mini_Shop_mit_Warenkorb_Simulation_WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="350">

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Bestellung abschließen"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

            <!-- Kundendaten -->
            <StackPanel Grid.Row="1" Width="300" HorizontalAlignment="Left">
                <TextBlock Text="Vorname"/>
                <TextBox Text="{Binding FirstName}" Margin="0,5"/>

                <TextBlock Text="Nachname"/>
                <TextBox Text="{Binding LastName}" Margin="0,5"/>

                <TextBlock Text="Email"/>
                <TextBox Text="{Binding Email}" Margin="0,5"/>

                <TextBlock Text="Gesamtpreis:" Margin="0,10,0,0"/>
                <TextBlock Text="{Binding TotalPrice, StringFormat='{}{0} €'}"
                       FontWeight="Bold"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

                <Button Content="Zurück"
                    Margin="0,0,10,0"
                    Command="{Binding BackCommand}"/>

                <Button Content="Rechnung erstellen"
                    Command="{Binding CreateInvoiceCommand}"/>
            </StackPanel>

        </Grid>
</UserControl>
