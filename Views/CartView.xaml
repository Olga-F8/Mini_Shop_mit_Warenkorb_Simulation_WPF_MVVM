<UserControl x:Class="Mini_Shop_mit_Warenkorb_Simulation_WPF.Views.CartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Mini_Shop_mit_Warenkorb_Simulation_WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Warenkorb Liste -->
            <DataGrid ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">

                <DataGrid.Columns>
                <DataGridTemplateColumn Header="Bild">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding Product.ImageUrl}" Width="30" Height="30"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Produkt"
                                    Binding="{Binding Product.Name}"
                                    IsReadOnly="True"/>

                    <DataGridTextColumn Header="Preis"
                                    Binding="{Binding UnitPrice}"
                                    IsReadOnly="True"/>

                    <DataGridTextColumn Header="Menge"
                                    Binding="{Binding Quantity}"
                                    IsReadOnly="True"/>

                    <DataGridTextColumn Header="Gesamt"
                                    Binding="{Binding Total}"
                                    IsReadOnly="True"/>

                    <!-- + Button -->
                    <DataGridTemplateColumn Header="+">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="+"
                                    Width="30"
                                    Command="{Binding DataContext.IncreaseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- - Button -->
                    <DataGridTemplateColumn Header="-">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="-"
                                    Width="30"
                                    Command="{Binding DataContext.DecreaseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Entfernen -->
                    <DataGridTemplateColumn Header="X">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X"
                                    Width="30"
                                    Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>

            <!-- Footer -->


        <Grid Grid.Row="1" Margin="0,10,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- LINKS: Message -->
            <TextBlock Text="{Binding Message}"
               Foreground="Green"
               FontWeight="Bold"
               VerticalAlignment="Center"
               Grid.Column="0"/>

            <!-- RECHTS: Gesamt + Button -->
            <StackPanel Orientation="Horizontal"
                Grid.Column="1"
                HorizontalAlignment="Right">

                <TextBlock Text="Gesamt: "
                   FontSize="16"
                   VerticalAlignment="Center"/>

                <TextBlock Text="{Binding TotalPrice, StringFormat='{}{0} €'}"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="5,0,20,0"
                   VerticalAlignment="Center"/>

                <Button Content="Bestellung abschließen"
                Width="200"
                Command="{Binding CheckoutCommand}" />

            </StackPanel>

        </Grid>
    </Grid>

    </UserControl>