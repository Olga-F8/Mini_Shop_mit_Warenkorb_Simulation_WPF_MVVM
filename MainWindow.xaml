<Window x:Class="Mini_Shop_mit_Warenkorb_Simulation_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Mini_Shop_mit_Warenkorb_Simulation_WPF"
        xmlns:views="clr-namespace:Mini_Shop_mit_Warenkorb_Simulation_WPF.Views"
        xmlns:vw="clr-namespace:Mini_Shop_mit_Warenkorb_Simulation_WPF.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <DataTemplate DataType="{x:Type vw:ProductListViewModel}">
            <views:ProductListView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vw:ProductDetailViewModel}">
            <views:ProductDetailView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vw:CartViewModel}">
            <views:CartView />
        </DataTemplate>

    </Window.Resources>
  
    <DockPanel>

        <!-- Top-Leiste -->
        <StackPanel Orientation="Horizontal"
                  DockPanel.Dock="Top"
                  Background="#2C3E50"
                  Height="50">

            <Button Content="Produkte"
                  Command="{Binding ShowProductsCommand}"
                  Margin="10"
                  Padding="10,5"/>

            <Button Content="Warenkorb ansehen"
                  Command="{Binding ShowCartCommand}"
                  Margin="10"
                  Padding="10,5"/>
        </StackPanel>

        <!-- Dynamischer Inhalt -->
        <ContentControl Content="{Binding CurrentView}" />

    </DockPanel>
</Window>
